<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>나와 닮은 포티 찾기</title>
<style>
:root{--bg:#f4f8fd;--card:#fff;--text:#142033;--muted:#667388;--line:#e4eaf2;--blue:#146fc4;--sky:#49a7f1;--navy:#063b76;--shadow:0 18px 50px rgba(29,58,95,.13)}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;font-family:"Pretendard","Noto Sans KR","Apple SD Gothic Neo",system-ui,sans-serif;color:var(--text);background:linear-gradient(180deg,#f7fbff,#f3f7fb)}
button,select{font:inherit}
.wrap{width:min(940px,calc(100% - 24px));margin:auto;padding:22px 0 48px}
.brand{font-weight:900;color:var(--navy);margin:0 0 14px 5px}
.card{background:#fff;border:1px solid #e2eaf4;border-radius:28px;overflow:hidden;box-shadow:var(--shadow)}
.screen{display:none}.screen.active{display:block}
.intro{padding:34px 26px}
.hero{text-align:center}
.kicker{display:inline-block;padding:7px 12px;border-radius:999px;background:#edf6ff;color:var(--blue);font-weight:900;font-size:13px}
h1{font-size:clamp(34px,7vw,52px);line-height:1.15;letter-spacing:-.045em;margin:16px 0 12px}
.hero p{margin:0 auto;max-width:620px;color:var(--muted);line-height:1.75}
.airport-panel{max-width:680px;margin:26px auto 0;padding:22px;border:1px solid var(--line);border-radius:22px;background:#f9fbfe;text-align:left}
.airport-panel label{display:block;font-weight:900;margin-bottom:9px}
.airport-panel select{width:100%;padding:15px 14px;border:1.5px solid #cfd9e6;border-radius:14px;background:#fff;color:var(--text)}
.airport-panel small{display:block;color:var(--muted);margin-top:8px;line-height:1.5}
.rank{max-width:680px;margin:16px auto 0;padding:20px;border-radius:22px;background:linear-gradient(135deg,#073d78,#1678d2);color:#fff;text-align:left}
.rank h2{margin:0 0 14px;font-size:21px}
.rank-row{display:flex;justify-content:space-between;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.18);font-weight:800}
.rank-row:last-of-type{border-bottom:0}
.hot{margin-top:14px;padding:13px 14px;border-radius:14px;background:rgba(255,255,255,.13);line-height:1.55}
.rank-note{margin-top:9px;font-size:11px;color:rgba(255,255,255,.72)}
.four{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:26px auto 22px}
.porty-card{border-radius:18px;overflow:hidden;border:1px solid var(--line);background:#fff}
.porty-card img{width:100%;height:auto;display:block}
.btn{border:0;border-radius:15px;padding:15px 23px;font-weight:900;cursor:pointer}
.primary{background:linear-gradient(135deg,#0c72c9,#48a6ef);color:#fff}
.light{background:#eff3f7;color:#314054}
.start-wrap{text-align:center}
.note{font-size:12px;color:#8a94a3;line-height:1.55;margin-top:14px}
.quiz-head{padding:20px 24px 16px;border-bottom:1px solid var(--line)}
.head-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.counter{font-weight:950;color:var(--blue)}.category{font-size:12px;padding:6px 10px;border-radius:999px;background:#f1f4f8;color:#5f6978;font-weight:800}
.selected-airport{font-size:13px;color:#566175;font-weight:800;margin-top:7px}
.progress{height:9px;border-radius:999px;background:#edf1f6;overflow:hidden}.progress div{height:100%;background:linear-gradient(90deg,#0d73ca,#4aa8f3);width:0}
.quiz-body{padding:28px 24px 25px}
.question{font-size:clamp(22px,4vw,29px);line-height:1.5;margin:0 0 22px}
.options{display:grid;gap:12px}
.option{width:100%;text-align:left;display:flex;gap:12px;padding:16px;border:1.5px solid var(--line);border-radius:17px;background:#fff;line-height:1.55;cursor:pointer}
.option.selected{border-color:#1674c8;background:#eef7ff}
.letter{flex:0 0 31px;height:31px;border-radius:10px;background:#eef2f6;display:grid;place-items:center;font-weight:950}
.option.selected .letter{background:#1674c8;color:#fff}
.nav{display:flex;justify-content:space-between;gap:10px;margin-top:22px}
.result{padding:32px 28px;text-align:center}
.result-badge{display:inline-block;padding:7px 12px;border-radius:999px;font-size:13px;font-weight:950}
.result-airport{margin:12px 0 0;font-weight:900;color:var(--blue)}
.result img{width:min(360px,82vw);height:auto;display:block;margin:16px auto;border-radius:20px}
.result h2{font-size:clamp(34px,7vw,50px);margin:0}
.result-sub{font-weight:900;font-size:18px;margin:8px 0 18px}
.result-desc{text-align:left;line-height:1.8;padding:19px;border-radius:18px;background:#f8fafc;border:1px solid var(--line)}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:14px 0;text-align:left}
.box{border:1px solid var(--line);border-radius:17px;padding:16px;background:#fff}
.box b{display:block;margin-bottom:7px}.box span{font-size:14px;line-height:1.6;color:var(--muted)}
.actions{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-top:22px}
@media(max-width:760px){.four{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.intro{padding:29px 16px}.quiz-head{padding:18px 17px 14px}.quiz-body{padding:24px 17px 20px}.result{padding:28px 17px}.grid{grid-template-columns:1fr}.nav{flex-direction:column-reverse}.nav button{width:100%}}
</style>
</head>
<body>
<main class="wrap">
<div class="brand">✈ KAC 포티 성격유형검사</div>
<section class="card">
<div id="startScreen" class="screen active">
<div class="intro">
<div class="hero">
<span class="kicker">14개 공항이 함께하는 참여형 검사</span>
<h1>나와 닮은 포티는<br>누구일까요?</h1>
<p>먼저 소속 공항을 선택한 뒤, 업무 상황에서 내가 주로 어떤 기준으로 판단하고 행동하는지 확인해보세요.</p>
</div>

<div class="airport-panel">
<label for="airportSelect">✈ 나의 공항 선택</label>
<select id="airportSelect">
<option value="">공항을 선택해 주세요</option>
<option value="김포공항">김포공항</option><option value="김해공항">김해공항</option><option value="제주공항">제주공항</option><option value="대구공항">대구공항</option><option value="광주공항">광주공항</option><option value="청주공항">청주공항</option><option value="양양공항">양양공항</option><option value="무안공항">무안공항</option><option value="울산공항">울산공항</option><option value="여수공항">여수공항</option><option value="사천공항">사천공항</option><option value="포항경주공항">포항경주공항</option><option value="군산공항">군산공항</option><option value="원주공항">원주공항</option>
</select>
<small>선택한 공항은 검사 결과 화면에 표시됩니다.</small>
</div>

<div class="rank">
<h2>🏆 이번 주 참여 순위</h2>
<div class="rank-row"><span>🥇 제주공항</span><span>83% 참여</span></div>
<div class="rank-row"><span>🥈 김포공항</span><span>76%</span></div>
<div class="rank-row"><span>🥉 청주공항</span><span>68%</span></div>
<div class="hot">🔥 현재 가장 빠르게 올라오는 공항<br><strong>→ 김해공항 +12%</strong></div>
<div class="rank-note">※ 현재 순위는 화면 구성을 위한 예시 데이터입니다. 실제 참여율 자동 집계에는 별도 서버 또는 설문 연동이 필요합니다.</div>
</div>

<div class="four">
<div class="porty-card"><img src="data:image/png;base64," alt="FAIR PORTY"></div>
<div class="porty-card"><img src="data:image/png;base64," alt="SAFE PORTY"></div>
<div class="porty-card"><img src="data:image/png;base64," alt="CARE PORTY"></div>
<div class="porty-card"><img src="data:image/png;base64," alt="LINK PORTY"></div>
</div>
<div class="start-wrap">
<button class="btn primary" onclick="startQuiz()">검사 시작하기</button>
<div class="note">본 검사는 캠페인 참여를 위한 간이 콘텐츠이며 인사평가나 심리 진단에 사용되지 않습니다.</div>
</div>
</div>
</div>

<div id="quizScreen" class="screen">
<div class="quiz-head">
<div class="head-row"><div id="counter" class="counter"></div><div id="category" class="category"></div></div>
<div id="selectedAirport" class="selected-airport"></div>
<div class="progress"><div id="progressBar"></div></div>
</div>
<div class="quiz-body">
<h2 id="questionText" class="question"></h2>
<div id="options" class="options"></div>
<div class="nav"><button id="prevBtn" class="btn light" onclick="prevQuestion()">이전</button><button id="nextBtn" class="btn primary" onclick="nextQuestion()" disabled>다음</button></div>
</div>
</div>

<div id="resultScreen" class="screen">
<div class="result">
<span id="resultBadge" class="result-badge"></span>
<div id="resultAirport" class="result-airport"></div>
<img id="resultImage" src="" alt="">
<h2 id="resultTitle"></h2>
<div id="resultSub" class="result-sub"></div>
<div id="resultDesc" class="result-desc"></div>
<div class="grid"><div class="box"><b>당신의 강점</b><span id="resultStrength"></span></div><div class="box"><b>실천 포인트</b><span id="resultTip"></span></div></div>
<div class="actions"><button class="btn primary" onclick="copyResult()">결과 복사</button><button class="btn light" onclick="restartQuiz()">다시 검사하기</button></div>
</div>
</div>
</section>
</main>
<script>
const questions=[
{category:"일반 내부통제",q:"부서 간 의견 충돌이 생겼다.",options:["관련 규정과 기준을 다시 정리해 원칙을 확인한다.","양측이 자유롭게 의견을 낼 수 있는 자리를 만든다.","실제 데이터와 근거 자료를 재확인한다.","전체 업무 흐름을 고려해 절충안을 제시한다."]},
{category:"일반 내부통제",q:"예산 집행 과정에서 규정 해석이 애매한 상황이 발생했다.",options:["유권해석이나 선례를 찾아 기준을 확립한다.","관련 부서와 협의해 공감대를 형성한다.","유사 사례의 집행 데이터를 비교·분석한다.","예산 목적과 전체 상황을 고려해 합리적으로 판단한다."]},
{category:"일반 내부통제",q:"동일한 유형의 오류가 반복적으로 발생하고 있다.",options:["표준 매뉴얼을 재정비해 기준을 명확히 한다.","담당자들과 함께 논의하며 원인을 공유한다.","반복 발생 데이터를 분석해 근본 원인을 찾는다.","전체 프로세스를 재설계하는 관점에서 접근한다."]},
{category:"인권 관련",q:"공항 현장 내 AI 서비스 확대 방안을 논의 중이다.",options:["교통약자까지 고려해 이용 기준을 점검한다.","차별 발생 가능 요소를 점검한다.","안전 기준 충족 여부를 우선 확인한다.","운영 기준과 적용 절차부터 수립한다."]},
{category:"일반 내부통제",q:"급한 요청 때문에 확인 절차를 건너뛰고 싶은 유혹이 든다.",options:["아무리 급해도 확인 절차는 지킨다.","담당자와 상의해 현실적인 방법을 찾는다.","절차를 건너뛸 때의 리스크를 먼저 따져본다.","긴급성과 절차 준수 사이에서 균형점을 찾는다."]},
{category:"직장 내 괴롭힘",q:"특정 직원만 지속적으로 업무에서 배제되고 있다.",options:["업무 분장 기준에 따라 배분이 적절한지 확인한다.","해당 직원과 편하게 이야기를 나눠본다.","실제 업무 배분 현황을 데이터로 확인한다.","팀 전체의 협업 방식을 재점검한다."]},
{category:"성실 의무",q:"동료가 근무시간 중 사적인 용무를 자주 처리하는 것을 알게 되었다.",options:["근무 기강 관련 기준을 다시 살펴본다.","동료에게 편하게 상황을 물어본다.","얼마나 자주 그런 일이 있었는지 확인해본다.","업무 영향과 관계를 함께 고려해 대응한다."]},
{category:"공항 공용업무",q:"귀빈(VIP) 이용객 측에서 특별한 편의를 요청해왔다.",options:["제공 가능한 범위의 기준을 먼저 확인한다.","요청 배경을 듣고 정중하게 안내한다.","유사 요청 사례를 참고해 판단한다.","형평성과 상황을 함께 고려해 결정한다."]},
{category:"청렴·소통",q:"후배가 업무 사용법을 몰라 여러 번 질문한다.",options:["매뉴얼을 안내해 스스로 찾아보게 한다.","편하게 물어보라고 하며 직접 알려준다.","어떤 질문이 반복되는지 확인해본다.","질문하기 편한 분위기와 업무 효율 사이에서 방법을 찾는다."]},
{category:"청렴·소통",q:"선후배 간 보고 방식에 대한 선호가 다르다.",options:["정해진 보고 기준이 있는지 확인한다.","선호하는 방식을 서로 편하게 대화한다.","각 보고 방식의 장단점을 비교한다.","상황에 맞게 보고 방식을 유연하게 조율한다."]}
];
const types={
A:{name:"FAIR PORTY",sub:"공정 포티 · 원칙수호형",img:"data:image/png;base64,",color:"#F3A900",soft:"#FFF4CF",desc:"원칙과 기준을 바탕으로 공정하고 투명하게 판단하는 유형입니다.",strength:"규정 준수, 공정한 판단, 투명한 업무 처리",tip:"다양한 상황과 구성원의 의견도 함께 들어보세요."},
B:{name:"LINK PORTY",sub:"링크 포티 · 소통협력형",img:"data:image/png;base64,",color:"#4AAE3C",soft:"#EDF8EB",desc:"대화와 협력을 통해 문제를 해결하는 유형입니다.",strength:"경청, 소통, 협업, 갈등 완화",tip:"대화 이후에는 실행 기준과 역할을 명확히 정리해보세요."},
C:{name:"SAFE PORTY",sub:"안전 포티 · 위험분석형",img:"data:image/png;base64,",color:"#E33A2C",soft:"#FDECEA",desc:"자료와 실제 사례를 바탕으로 위험을 먼저 살피는 유형입니다.",strength:"위험 분석, 객관적 판단, 오류 탐지",tip:"필요한 정보 범위와 판단 시점을 정해두세요."},
D:{name:"CARE PORTY",sub:"케어 포티 · 배려조정형",img:"data:image/png;base64,",color:"#7650B9",soft:"#F1ECFA",desc:"사람과 상황을 함께 고려해 모두가 존중받는 방향을 찾는 유형입니다.",strength:"존중, 배려, 다양성 고려, 상황 조정",tip:"판단 근거를 기록해 일관성과 투명성을 확보하세요."}
};
let current=0,answers=Array(questions.length).fill(null),selectedAirport="";
function show(id){document.querySelectorAll(".screen").forEach(x=>x.classList.remove("active"));document.getElementById(id).classList.add("active");window.scrollTo(0,0)}
function startQuiz(){
 selectedAirport=document.getElementById("airportSelect").value;
 if(!selectedAirport){alert("먼저 나의 공항을 선택해 주세요.");return;}
 localStorage.setItem("selectedAirport",selectedAirport);
 current=0;answers=Array(questions.length).fill(null);
 document.getElementById("selectedAirport").textContent="선택 공항: "+selectedAirport;
 show("quizScreen");render();
}
function render(){const item=questions[current];counter.textContent=`Q${current+1} / ${questions.length}`;category.textContent=item.category;progressBar.style.width=`${(current+1)/questions.length*100}%`;questionText.textContent=item.q;options.innerHTML="";item.options.forEach((t,i)=>{const b=document.createElement("button");b.className="option"+(answers[current]===i?" selected":"");b.innerHTML=`<span class="letter">${"ABCD"[i]}</span><span>${t}</span>`;b.onclick=()=>{answers[current]=i;render()};options.appendChild(b)});prevBtn.style.visibility=current===0?"hidden":"visible";nextBtn.disabled=answers[current]===null;nextBtn.textContent=current===questions.length-1?"결과 보기":"다음"}
function nextQuestion(){if(answers[current]===null)return;if(current<questions.length-1){current++;render()}else showResult()}
function prevQuestion(){if(current>0){current--;render()}}
function showResult(){const scores=[0,0,0,0];answers.forEach(v=>scores[v]++);const max=Math.max(...scores),keys=["A","B","C","D"],wins=keys.filter((k,i)=>scores[i]===max),t=types[wins[0]];resultBadge.textContent="나와 가장 닮은 포티";resultBadge.style.background=t.soft;resultBadge.style.color=t.color;resultAirport.textContent=selectedAirport+" 참여 결과";resultImage.src=t.img;resultTitle.textContent=t.name;resultSub.textContent=t.sub;resultDesc.textContent=t.desc;resultStrength.textContent=t.strength;resultTip.textContent=t.tip;show("resultScreen")}
function copyResult(){const text=`${selectedAirport}에서 참여한 나의 포티는 [${resultTitle.textContent}]입니다.`;navigator.clipboard.writeText(text).then(()=>alert("결과가 복사되었습니다."))}
function restartQuiz(){document.getElementById("airportSelect").value=selectedAirport;show("startScreen")}
window.addEventListener("DOMContentLoaded",()=>{const saved=localStorage.getItem("selectedAirport");if(saved)document.getElementById("airportSelect").value=saved;});
</script>
</body>
</html>
